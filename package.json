{
  "name": "scm-data-governance-workbench-v0",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "import": "node scripts/import-assets.mjs",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "node server/index.mjs",
    "build": "tsc && vite build",
    "init": "npm run import && npm run build",
    "start": "node server/index.mjs",
    "start:cloud": "HOST=0.0.0.0 NODE_ENV=production node server/index.mjs",
    "health": "node -e \"fetch('http://127.0.0.1:'+(process.env.PORT||5174)+'/api/deploy/health').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "check": "tsc --noEmit",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:database-gate": "node scripts/smoke-database-gate.mjs",
    "smoke:import-gate": "node scripts/smoke-import-gate.mjs",
    "smoke:manual-gate-receipts": "node scripts/smoke-manual-gate-receipts.mjs",
    "smoke:migration-gate": "node scripts/smoke-migration-gate.mjs",
    "smoke:path-contract": "node scripts/smoke-path-contract.mjs",
    "smoke:provider-gate": "node scripts/smoke-provider-gate.mjs",
    "smoke:deepseek-live": "node scripts/smoke-deepseek-live.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "smoke:readonly": "node scripts/smoke-readonly.mjs",
    "audit:ui-baseline": "node scripts/audit-ui-baseline.mjs",
    "preprod:check": "node scripts/preprod-check.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright": "^1.61.0"
  }
}
